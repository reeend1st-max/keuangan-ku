# Copy this file to .env for local development (used by `npm run dev`).
# On Vercel, set these as real Environment Variables in:
#   Project Settings → Environment Variables
# DO NOT commit a real .env file to GitHub.

# ── Supabase Project URL ─────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project URL
# Format: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# ── Supabase Anon (public) Key ───────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon public
# This key is DESIGNED to be public and safe to expose in frontend code.
# Actual data protection comes from Row Level Security (RLS) policies,
# defined in supabase/schema.sql — not from hiding this key.
SUPABASE_ANON_KEY=your-anon-public-key-here
